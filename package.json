{
  "name": "openai-product-atlas",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "data:collect": "node scripts/collect-official-sources.mjs",
    "data:build": "node scripts/build-timeline-data.mjs",
    "data:validate": "node scripts/validate-timeline-data.mjs",
    "research:build": "node scripts/build-research-ledger.mjs",
    "test:unit": "node --experimental-strip-types --test tests/*.test.mjs tests/*.test.ts",
    "test": "npm run test:unit && npm run data:validate && npm run build",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "type": "module"
}
